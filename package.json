{
  "name": "tochukwunkwocha-site",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "build:blog": "node scripts/build-blog.js",
    "build:sitemap": "node scripts/build-sitemap.js",
    "build:assets": "node scripts/build-assets.js",
    "build:assets:rewrite": "node scripts/build-assets.js --rewrite-html",
    "build": "npm run build:blog && npm run build:sitemap && npm run build:assets:rewrite && npm run build:images",
    "brevo:ai-lessons:drafts": "node scripts/brevo-create-ai-lesson-drafts.js",
    "brevo:ai-lessons:templates": "node scripts/brevo-create-ai-lesson-templates.js",
